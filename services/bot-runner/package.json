{
  "name": "ai-notetaker-bot-runner",
  "version": "0.1.0",
  "description": "Electron app with Webex Browser SDK integration",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "electron": "^27.0.0",
    "webex": "^3.0.0",
    "crypto-js": "^4.1.1",
    "ws": "^8.14.0",
    "axios": "^1.5.0",
    "dotenv": "^16.3.0"
  },
  "devDependencies": {
    "electron-builder": "^24.6.0",
    "@types/node": "^20.8.0",
    "@types/ws": "^8.5.0", 
    "@types/crypto-js": "^4.1.2",
    "typescript": "^5.2.0",
    "ts-node": "^10.9.0"
  },
  "build": {
    "appId": "com.ainotetaker.botrunner",
    "productName": "AI Notetaker Bot Runner",
    "directories": {
      "output": "dist"
    }
  }
}
