# Webex Guest Issuer Authentication (Required)
# Get these from: https://developer.webex.com/my-apps -> Create Integration
WEBEX_GUEST_ISSUER_ID=your-guest-issuer-id-here
WEBEX_GUEST_ISSUER_SECRET=your-guest-issuer-secret-here

# Bot Identity Configuration
BOT_NAME=AI Notetaker
BOT_DISPLAY_NAME=AI Meeting Notetaker
BOT_EMAIL=ai-notetaker@yourcompany.com

# Backend API Configuration
BACKEND_API_URL=http://localhost:8000
BACKEND_WS_URL=ws://localhost:8000
BOT_SERVICE_TOKEN=your-bot-service-token-here

# Audio Processing Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_DURATION_MS=8000
AUDIO_OVERLAP_MS=250
AUDIO_QUALITY=high

# Meeting Configuration
AUTO_JOIN_DELAY_MS=2000
ANNOUNCEMENT_ENABLED=true
ANNOUNCEMENT_TEXT=Hello! I'm the AI Meeting Notetaker. I'll be transcribing this meeting for participants.
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=5000

# Development Configuration
NODE_ENV=development
LOG_LEVEL=info
ENABLE_WEBEX_LOGS=false

# Webex API Configuration
WEBEX_API_BASE_URL=https://webexapis.com/v1

# Security Configuration (Development Only)
DISABLE_WEB_SECURITY=true
ALLOW_RUNNING_INSECURE_CONTENT=true

# Error Handling
ENABLE_CRASH_REPORTING=false
AUTO_RESTART_ON_CRASH=true

# Audio WebSocket Configuration
WS_RECONNECT_DELAY_MS=1000
WS_MAX_RECONNECT_ATTEMPTS=5
WS_PING_INTERVAL_MS=30000

# Bot API Server Configuration
BOT_API_PORT=3001
BOT_API_HOST=127.0.0.1
