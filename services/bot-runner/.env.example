# Webex Authentication (use either Guest Issuer OR Access Token)
# For Guest Issuer (requires subscribed account):
WEBEX_GUEST_ISSUER_ID=your-guest-issuer-id-here
WEBEX_GUEST_ISSUER_SECRET=your-guest-issuer-secret-here

# For Personal Access Token (fallback for personal accounts):
WEBEX_ACCESS_TOKEN=your-personal-access-token-here

# Bot Configuration  
BOT_NAME=AI Space Notetaker
BOT_SERVICE_TOKEN=your-bot-service-token-here

# Backend API
BACKEND_API_URL=http://localhost:8000
BACKEND_WS_URL=ws://localhost:8000

# Audio Configuration
AUDIO_CHUNK_DURATION_MS=8000
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Meeting Configuration
AUTO_JOIN_DELAY_MS=2000
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=5000

# Development
NODE_ENV=development
ELECTRON_ENABLE_LOGGING=true
