# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ai_notetaker

# Redis
REDIS_URL=redis://localhost:6379

# MinIO/S3
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=ai-notetaker
S3_ARTIFACTS_BUCKET=artifacts

# API
API_V1_STR=/api/v1
PROJECT_NAME=AI Meeting Notetaker

# Bot Service Authentication
BOT_SERVICE_TOKEN=your-bot-service-token-here

# AI Services
GROQ_API_KEY=your-groq-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Whisper Configuration
WHISPER_MODEL=whisper-large-v3-turbo
WHISPER_LANGUAGE=auto  # auto-detect language, or specify: en, es, fr, de, etc.

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Job Queue Configuration
REDIS_QUEUE_NAME=ai-notetaker-jobs
WORKER_CONCURRENCY=2

# Bot Runner Configuration
BOT_RUNNER_URL=http://127.0.0.1:3001
